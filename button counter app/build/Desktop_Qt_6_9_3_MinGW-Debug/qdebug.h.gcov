        -:  658:
        -:  659:#if !defined(QT_NO_QOBJECT) && !defined(Q_QDOC)
        -:  660:// Debugging of plain enums. There are three cases:
        -:  661://  1) the enum is part of a Q_DECLARE_FLAGS and there's a Q_FLAG for that
        -:  662://     -> debugs as that QFlags (even if a Q_ENUM is present)
        -:  663://  2) the enum is declared a Q_ENUM but is not part of a Q_DECLARE_FLAGS
        -:  664://     -> debugs via qt_QMetaEnum_debugOperator()
        -:  665://  3) the enum is not associated with a QMetaObject
        -:  666://     -> no streaming
        -:  667:// To avoid ambiguity in overload resolution, the template conditions are
        -:  668:// mutually exclusive.
        -:  669:
        -:  670:namespace QtPrivate {
        -:  671:template <typename T, bool IsEnum = std::is_enum_v<T>, bool = sizeof(T) <= sizeof(quint64)>
        -:  672:struct EnumHasQFlag { static constexpr bool Value = false; };
        -:  673:template <typename T> struct EnumHasQFlag<T, true, true> : QtPrivate::IsQEnumHelper<QFlags<T>> {};
        -:  674:
        -:  675:template <typename T, bool IsEnum = std::is_enum_v<T>, bool HasQFlag = EnumHasQFlag<T>::Value>
        -:  676:struct EnumHasQEnum { static constexpr bool Value = false; };
        -:  677:template <typename T> struct EnumHasQEnum<T, true, false> : QtPrivate::IsQEnumHelper<T> {};
        -:  678:}
        -:  679:
        -:  680:template <typename T>
        -:  681:std::enable_if_t<QtPrivate::EnumHasQFlag<T>::Value, QDebug> // case 1
        -:  682:operator<<(QDebug debug, T flag)
        -:  683:{
        -:  684:    return debug << QFlags(flag);
        -:  685:}
        -:  686:
        -:  687:template<typename T>
        -:  688:std::enable_if_t<QtPrivate::EnumHasQEnum<T>::Value, QDebug> // case 2
        -:  689:operator<<(QDebug dbg, T value)
        -:  690:{
        -:  691:    const QMetaObject *obj = qt_getEnumMetaObject(value);
        -:  692:    const char *name = qt_getEnumName(value);
        -:  693:    return qt_QMetaEnum_debugOperator(dbg, static_cast<typename std::underlying_type<T>::type>(value), obj, name);
        -:  694:}
        -:  695:#endif // !QT_NO_QOBJECT && !Q_QDOC
