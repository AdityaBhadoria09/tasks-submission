        -:  756:#define Q_DECLARE_QDEBUG_OPERATOR_FOR_CF_TYPE(CFType) \
        -:  757:    QDebug operator<<(QDebug debug, CFType##Ref ref) \
        -:  758:    { \
        -:  759:        if (!ref) \
